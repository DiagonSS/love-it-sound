<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I love it love it love it</title>
    <style>
        body {
            background: #000;
            color: white;
            font-family: Arial, sans-serif;
            text-align: center;
            padding: 50px;
        }
        h1 {
            font-size: 2.5em;
            margin: 20px;
        }
        button {
            font-size: 2em;
            padding: 30px 60px;
            margin: 30px;
            background: #ff00aa;
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 0 30px #ff00aa;
        }
        button:hover {
            background: #ff33bb;
            transform: scale(1.05);
        }
        .subtitle {
            color: #aaa;
            margin-top: 40px;
        }
    </style>
</head>
<body>
    <h1>❤️ I LOVE IT, LOVE IT, LOVE IT ❤️</h1>
    
    <button onclick="playSound()">▶️ Воспроизвести звук</button>
    
    <p class="subtitle">Нажми кнопку — звук сразу играет</p>

    <audio id="sound" src="https://github.com/ТВОЙ_НИК/sound/raw/main/myinstants.mp3"></audio>

    <script>
        function playSound() {
            const audio = document.getElementById('sound');
            audio.currentTime = 0;
            audio.play();
        }
        
        // Автозапуск при загрузке страницы (многие браузеры блокируют, поэтому кнопка надёжнее)
        window.onload = function() {
            // Можно попробовать автозапуск
            setTimeout(() => {
                const audio = document.getElementById('sound');
                audio.play().catch(() => {});
            }, 800);
        };
    </script>
</body>
</html>
